{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Missing fields",
      "method": "POST",
      "path": "/",
      "body": {"service": "Тонировка"},
      "expectedStatus": 400,
      "expectedBody": {"error": "Имя и телефон обязательны"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Submit lead",
      "method": "POST",
      "path": "/",
      "body": {"name": "Тест", "phone": "+79001234567", "service": "Тонировка 5%"},
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    }
  ]
}
